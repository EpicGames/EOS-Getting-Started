# UAT-generated alongside C# automation scripts (Build/Scripts/Automation/*.csproj).
# Records the absolute path to the engine the script was built against - per-developer.
*.csproj.props

# Local-only launch scripts with credentials live under batch/local/.
# Tutorial 9 moved these out of the project root and dropped the `.local.bat`
# suffix (the folder name already marks them as local).
batch/local/

# UE convention: Restricted/NoRedist, Restricted/NotForLicensees, Restricted/LimitedAccess
# contain files the engine auto-layers on top of committed configs but that must never ship.
Restricted/
# EngineBugs.md is for internal handoff to engine-side fixes; do NOT publish.
# This is a public tutorial repo - the file references local engine paths and
# may contain in-progress engine bug write-ups that aren't ready for upstream.
EngineBugs.md
